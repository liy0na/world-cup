# Server
HOST=0.0.0.0
PORT=8787
# Where the last-good snapshot is persisted (mount this as a volume in Docker).
DATA_DIR=./data
# Built SPA to serve in production (the Docker image sets this to the copied dist).
WEB_DIST=../web/dist

# Polling cadence (ms). The poller decouples upstream calls from browser updates.
POLL_LIVE_MS=45000
POLL_MATCHDAY_MS=600000
POLL_IDLE_MS=3600000

# Free data sources (no keys needed). Set FIFA_LIVE=false to disable the
# unofficial FIFA in-play overlay (e.g. if it breaks mid-tournament).
FIFA_LIVE=true
OPENFOOTBALL_BASE=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026

# Paid-ready (optional): set a key to enable a supported provider adapter.
# API_FOOTBALL_KEY=

LOG_LEVEL=info
